---
import Badge from '@/components/Badge.astro'
import DamageDown from "@/components/buff/DamageDown.astro";
import Span from "@/components/Span.vue"
import EventSection from "@/components/section/EventSection.astro";
import type { Time } from "@/lib/utils";
import { translations } from '../_translations/cn'

interface Props {
  time: Time
}

const { time }: Props = Astro.props
const phagocyteSpotlight = translations.PhagocyteSpotlight
---
<EventSection time={time} ability={phagocyteSpotlight}>  
    <Span variant="yellow">{phagocyteSpotlight}</Span>出现
    <Badge variant="green">5m圆形</Badge>
    <Badge variant="purple">点名8人</Badge>
    <Badge variant="yellow">黄圈</Badge>，3秒后判定伤害
    <DamageDown hover={true}/>

</EventSection>